# Environment: development, staging, production
ENVIRONMENT=development

# Supabase Configuration
SUPABASE_URL=https://[YOUR_PROJECT].supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# LangSmith Configuration
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=genai-governance
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# LLM Provider Configuration (AWS Bedrock)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# n8n Configuration
N8N_HOST=http://localhost:5678
N8N_API_KEY=your_n8n_api_key
N8N_WEBHOOK_BASE_URL=https://your-n8n-instance.com

# Integrations: PagerDuty
PAGERDUTY_API_KEY=your_pagerduty_api_key
PAGERDUTY_SERVICE_ID=your_pagerduty_service_id

# Integrations: Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Integrations: Resend (Email)
RESEND_API_KEY=your_resend_api_key
COMPLIANCE_ALERT_EMAIL=compliance@creditunion.org
COMPLIANCE_DIGEST_EMAIL=compliance@creditunion.org

# Trigger.dev Configuration
TRIGGER_API_KEY=your_trigger_dev_api_key
TRIGGER_PROJECT_ID=your_trigger_project_id

# Application Configuration
API_PORT=5000
API_HOST=0.0.0.0
LOG_LEVEL=INFO

# Compliance & Guardrail Configuration
GUARDRAIL_PII_THRESHOLD=0.95
GUARDRAIL_HALLUCINATION_THRESHOLD=0.85
GUARDRAIL_BIAS_THRESHOLD=0.10
GUARDRAIL_CONFIDENCE_THRESHOLD=0.70
AUDIT_LOG_RETENTION_DAYS=2555

# Feature Flags
ENABLE_GUARDRAILS=true
ENABLE_COMPLIANCE_LOGGING=true
ENABLE_MODEL_EVALUATION=true
ENABLE_COST_TRACKING=true
